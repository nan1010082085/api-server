# Database — MongoDB Atlas connection string
# For local Docker dev, use: mongodb://formgrid:formgrid@localhost:27017/formgrid
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.<id>.mongodb.net/?retryWrites=true&w=majority

# Server
PORT=3001
NODE_ENV=development

# CORS origins (comma-separated, or '*' to allow all)
CORS_ORIGINS=http://localhost:4000,http://localhost:5100,http://localhost:5200,http://localhost:5300,http://localhost:5400

# Skip permission check (set to 'true' for local dev, do NOT set in production)
# SKIP_PERMISSION_CHECK=true

# LLM — DeepSeek chat (对话模型)
DEEPSEEK_API_KEY=

# Set to 'false' to disable platform-managed LLM (env-based providers).
# When disabled, only DB-stored ModelConfig records can supply LLM credentials.
# PLATFORM_LLM_ENABLED=false

# Embedding — DeepSeek 不提供 Embedding API，向量检索需单独配置
# 推荐：SiliconFlow 托管 BGE-M3（免费、中文效果最佳、无需 GPU）
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.hpc-ai.com/inference/v1
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DIMENSIONS=1024
# 备选：OpenAI
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

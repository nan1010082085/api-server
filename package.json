{
  "name": "@server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": "yangdongnan",
  "description": "可视化设计器后端 — Koa.js + MongoDB，Schema 存储与 API 服务",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --dir ../ai/shared build && tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "db:up": "docker compose -f docker-compose.yml up -d",
    "db:down": "docker compose -f docker-compose.yml down",
    "db:seed": "tsx scripts/seed.ts",
    "db:fix-seed": "tsx scripts/fix-seed-data.ts",
    "db:migrate-id": "tsx scripts/migrate-to-objectid.ts",
    "plugin:validate": "tsx scripts/plugin-validate.ts",
    "plugin:pack": "tsx scripts/plugin-pack.ts",
    "plugin:install": "tsx scripts/plugin-install.ts",
    "openapi:extract": "tsx scripts/extract-routes.ts"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/multer": "^4.0.0",
    "@koa/router": "^13.1.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^0.2.60",
    "@langchain/langgraph-checkpoint": "^1.0.4",
    "@langchain/openai": "^1.4.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@schema-platform/ai-shared": "file:../ai/shared",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "koa": "^2.15.4",
    "koa-bodyparser": "^4.4.1",
    "koa-helmet": "^9.0.0",
    "koa-ratelimit": "^6.0.0",
    "mammoth": "^1.12.0",
    "mongoose": "^8.9.0",
    "openai": "^4.78.0",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.0",
    "uuid": "^11.1.0",
    "word-extractor": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa-ratelimit": "^5.0.5",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.4",
    "@types/node": "^22.13.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^10.0.0",
    "@vitest/runner": "^4.1.6",
    "tsx": "^4.19.0",
    "typescript": "~5.7.3",
    "vitest": "^3.2.4"
  }
}
